  tagBahagian: Mata
  namaPenyakit: Conjunctivitis (Mata)
  namaPenyakitEN: Conjunctivitis (Mata)
  tahapRisiko: Tahap 1
  tahapRisikoEN: Level 1
  gambar: {fileID: 21300000, guid: 757b5325ce017864db6a2e7bc4eda1d5, type: 3}
